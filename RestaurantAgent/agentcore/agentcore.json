{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "RestaurantAgent",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "RestaurantAgent"
  },
  "runtimes": [
    {
      "name": "MyRestaurantAgent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/MyRestaurantAgent/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "AGUI",
      "authorizerType": "CUSTOM_JWT",
      "authorizerConfiguration": {
        "customJwtAuthorizer": {
          "discoveryUrl": "https://cognito-idp.us-east-1.amazonaws.com/us-east-1_uXuMtLZYF/.well-known/openid-configuration",
          "allowedAudience": [],
          "allowedClients": ["3h9ul8re46q87rs2nj3ajm7ds1"]
        }
      }
    }
  ],
  "memories": [
    {
      "name": "RestaurantMemory",
      "eventExpiryDuration": 90,
      "strategies": [
        {
          "type": "SEMANTIC",
          "name": "user_facts",
          "namespaceTemplates": [
            "/strategies/{memoryStrategyId}/actors/{actorId}/"
          ]
        },
        {
          "type": "SUMMARIZATION",
          "name": "conversation_summaries",
          "namespaceTemplates": [
            "/strategies/{memoryStrategyId}/actors/{actorId}/sessions/{sessionId}/"
          ]
        }
      ]
    }
  ],
  "knowledgeBases": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "harnesses": [],
  "datasets": [],
  "payments": []
}